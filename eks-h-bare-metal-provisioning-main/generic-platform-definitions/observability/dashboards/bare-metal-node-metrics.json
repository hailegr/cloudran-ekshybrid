{
  "title": "Bare Metal Node Metrics",
  "tags": ["eks-h", "telegraf", "bare-metal"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "templating": {
    "list": [
      {"name": "datasource", "type": "datasource", "query": "prometheus", "label": "Data Source"},
      {"name": "cluster", "type": "query", "query": "label_values(cpu_usage_idle, cluster)", "datasource": {"type": "prometheus", "uid": "${datasource}"}, "current": {"text": "All", "value": "$__all"}, "includeAll": true, "allValue": ".*", "refresh": 2, "label": "Cluster"},
      {"name": "host", "type": "query", "query": "label_values(cpu_usage_idle{cluster=~\"$cluster\"}, host)", "datasource": {"type": "prometheus", "uid": "${datasource}"}, "current": {"text": "All", "value": "$__all"}, "includeAll": true, "allValue": ".*", "refresh": 2, "label": "Host"}
    ]
  },
  "panels": [
    {
      "id": 100, "title": "CPU", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "collapsed": false
    },
    {
      "id": 1, "title": "CPU Usage %", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "100 - cpu_usage_idle{cluster=~\"$cluster\", host=~\"$host\", cpu=\"cpu-total\"}", "legendFormat": "{{host}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0}}
    },
    {
      "id": 2, "title": "CPU Usage by Core", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "100 - cpu_usage_idle{cluster=~\"$cluster\", host=~\"$host\", cpu!=\"cpu-total\"}", "legendFormat": "{{host}} {{cpu}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0}}
    },
    {
      "id": 101, "title": "Memory", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}, "collapsed": false
    },
    {
      "id": 3, "title": "Memory Usage", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "mem_used{cluster=~\"$cluster\", host=~\"$host\"}", "legendFormat": "{{host}} used", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "mem_cached{cluster=~\"$cluster\", host=~\"$host\"}", "legendFormat": "{{host}} cached", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "mem_buffered{cluster=~\"$cluster\", host=~\"$host\"}", "legendFormat": "{{host}} buffered", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}}}
    },
    {
      "id": 4, "title": "Memory Usage %", "type": "gauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "mem_used_percent{cluster=~\"$cluster\", host=~\"$host\"}", "legendFormat": "{{host}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "min": 0, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 102, "title": "Disk", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18}, "collapsed": false
    },
    {
      "id": 5, "title": "Disk Usage", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "disk_used{cluster=~\"$cluster\", host=~\"$host\"}", "legendFormat": "{{host}} {{path}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 6, "title": "Disk Usage %", "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "disk_used_percent{cluster=~\"$cluster\", host=~\"$host\"}", "legendFormat": "{{host}} {{path}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 103, "title": "Network", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27}, "collapsed": false
    },
    {
      "id": 7, "title": "Network Throughput", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "rate(net_bytes_recv{cluster=~\"$cluster\", host=~\"$host\", interface!=\"lo\"}[5m])", "legendFormat": "{{host}} {{interface}} rx", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "rate(net_bytes_sent{cluster=~\"$cluster\", host=~\"$host\", interface!=\"lo\"}[5m])", "legendFormat": "{{host}} {{interface}} tx", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "id": 8, "title": "Network Packets/s", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "rate(net_packets_recv{cluster=~\"$cluster\", host=~\"$host\", interface!=\"lo\"}[5m])", "legendFormat": "{{host}} {{interface}} rx", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "rate(net_packets_sent{cluster=~\"$cluster\", host=~\"$host\", interface!=\"lo\"}[5m])", "legendFormat": "{{host}} {{interface}} tx", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "pps"}}
    },
    {
      "id": 9, "title": "Network Errors", "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 36},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "rate(net_err_in{cluster=~\"$cluster\", host=~\"$host\", interface!=\"lo\"}[5m])", "legendFormat": "{{host}} {{interface}} err_in", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "rate(net_err_out{cluster=~\"$cluster\", host=~\"$host\", interface!=\"lo\"}[5m])", "legendFormat": "{{host}} {{interface}} err_out", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "rate(net_drop_in{cluster=~\"$cluster\", host=~\"$host\", interface!=\"lo\"}[5m])", "legendFormat": "{{host}} {{interface}} drop_in", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "rate(net_drop_out{cluster=~\"$cluster\", host=~\"$host\", interface!=\"lo\"}[5m])", "legendFormat": "{{host}} {{interface}} drop_out", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 10}}}
    },
    {
      "id": 104, "title": "Ethtool (NIC Hardware)", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 44}, "collapsed": false
    },
    {
      "id": 10, "title": "Ethtool RX Packets", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 45},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "rate(ethtool_rx_packets{cluster=~\"$cluster\", host=~\"$host\"}[5m])", "legendFormat": "{{host}} {{interface}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "pps"}}
    },
    {
      "id": 11, "title": "Ethtool TX Packets", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 45},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "rate(ethtool_tx_packets{cluster=~\"$cluster\", host=~\"$host\"}[5m])", "legendFormat": "{{host}} {{interface}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "pps"}}
    }
  ]
}
