{
  "title": "Tinkerbell Stack",
  "tags": ["eks-h", "tinkerbell"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "templating": {
    "list": [
      {"name": "datasource", "type": "datasource", "query": "prometheus", "label": "Data Source"},
      {"name": "cluster", "type": "query", "query": "label_values(up, cluster)", "datasource": {"type": "prometheus", "uid": "${datasource}"}, "current": {"text": "All", "value": "$__all"}, "includeAll": true, "allValue": ".*", "refresh": 2, "label": "Cluster"}
    ]
  },
  "panels": [
    {
      "id": 100, "title": "Tinkerbell Stack Components", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "collapsed": false
    },
    {
      "id": 1, "title": "Tinkerbell Pod CPU", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", pod=~\"tinkerbell-.*\", container!=\"\"}[5m]))", "legendFormat": "{{pod}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 10}}}
    },
    {
      "id": 2, "title": "Tinkerbell Pod Memory", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod) (container_memory_working_set_bytes{cluster=~\"$cluster\", pod=~\"tinkerbell-.*\", container!=\"\"})", "legendFormat": "{{pod}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"fillOpacity": 10}}}
    },
    {
      "id": 101, "title": "Image Server", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}, "collapsed": false
    },
    {
      "id": 3, "title": "Image Server CPU", "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod, container) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", pod=~\"image-server-.*\", container!=\"\"}[5m]))", "legendFormat": "{{pod}}/{{container}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4, "title": "Image Server Memory", "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 10},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod, container) (container_memory_working_set_bytes{cluster=~\"$cluster\", pod=~\"image-server-.*\", container!=\"\"})", "legendFormat": "{{pod}}/{{container}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 5, "title": "Image Server Network I/O", "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 10},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum by (pod) (rate(container_network_receive_bytes_total{cluster=~\"$cluster\", pod=~\"image-server-.*\"}[5m]))", "legendFormat": "{{pod}} rx", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "sum by (pod) (rate(container_network_transmit_bytes_total{cluster=~\"$cluster\", pod=~\"image-server-.*\"}[5m]))", "legendFormat": "{{pod}} tx", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "id": 102, "title": "Action Registry", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18}, "collapsed": false
    },
    {
      "id": 6, "title": "Action Registry CPU", "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 19},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod, container) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", pod=~\"action-registry-.*\", container!=\"\"}[5m]))", "legendFormat": "{{pod}}/{{container}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 7, "title": "Action Registry Memory", "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 19},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod, container) (container_memory_working_set_bytes{cluster=~\"$cluster\", pod=~\"action-registry-.*\", container!=\"\"})", "legendFormat": "{{pod}}/{{container}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 8, "title": "Action Registry Network I/O", "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 19},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum by (pod) (rate(container_network_receive_bytes_total{cluster=~\"$cluster\", pod=~\"action-registry-.*\"}[5m]))", "legendFormat": "{{pod}} rx", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "sum by (pod) (rate(container_network_transmit_bytes_total{cluster=~\"$cluster\", pod=~\"action-registry-.*\"}[5m]))", "legendFormat": "{{pod}} tx", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "id": 103, "title": "HookOS", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27}, "collapsed": false
    },
    {
      "id": 9, "title": "HookOS Pod CPU", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", pod=~\"hookos-.*\", container!=\"\"}[5m]))", "legendFormat": "{{pod}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 10, "title": "HookOS Pod Memory", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod) (container_memory_working_set_bytes{cluster=~\"$cluster\", pod=~\"hookos-.*\", container!=\"\"})", "legendFormat": "{{pod}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 104, "title": "Platform Components (Telegraf, Multus, SR-IOV)", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36}, "collapsed": false
    },
    {
      "id": 11, "title": "Platform Pod CPU", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", pod=~\"platform-.*\", container!=\"\"}[5m]))", "legendFormat": "{{pod}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 12, "title": "Platform Pod Memory", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod) (container_memory_working_set_bytes{cluster=~\"$cluster\", pod=~\"platform-.*\", container!=\"\"})", "legendFormat": "{{pod}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 105, "title": "All Tinkerbell Namespace Summary", "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 45}, "collapsed": false
    },
    {
      "id": 13, "title": "Total CPU by Component", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 46},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", pod=~\"tinkerbell-.*|image-server-.*|action-registry-.*|hookos-.*\", container!=\"\"}[5m]))", "legendFormat": "{{pod}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}}}
    },
    {
      "id": 14, "title": "Total Memory by Component", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 46},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by (pod) (container_memory_working_set_bytes{cluster=~\"$cluster\", pod=~\"tinkerbell-.*|image-server-.*|action-registry-.*|hookos-.*\", container!=\"\"})", "legendFormat": "{{pod}}", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}}}
    }
  ]
}
