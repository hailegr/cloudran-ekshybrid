{
  "title": "Node Distribution",
  "tags": [
    "eks-h"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Data Source"
      },
      {
        "name": "cluster",
        "type": "query",
        "query": "label_values(up, cluster)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "allValue": ".*",
        "refresh": 2,
        "label": "Cluster"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Nodes by Instance Type",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "count by (node_kubernetes_io_instance_type) (kubelet_node_name{cluster=~\"$cluster\"})",
          "legendFormat": "{{node_kubernetes_io_instance_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 2,
      "title": "Nodes by Zone",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "count by (topology_kubernetes_io_zone) (kubelet_node_name{cluster=~\"$cluster\"})",
          "legendFormat": "{{topology_kubernetes_io_zone}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Pods per Node",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "kubelet_running_pods{cluster=~\"$cluster\"}",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU Cores per Node",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "machine_cpu_cores{cluster=~\"$cluster\"}",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Memory per Node",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "machine_memory_bytes{cluster=~\"$cluster\"}",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    }
  ]
}